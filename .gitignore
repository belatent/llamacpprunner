# ========================
# Python
# ========================
# __pycache__/ 不带前导斜杠，递归匹配所有子目录
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
*.spec

# ========================
# 虚拟环境
# ========================
.venv/
venv/
env/
ENV/

# ========================
# 日志文件
# ========================
*.log

# ========================
# 配置 / 运行时状态
# ========================
/config/state.json
/config/profiles/

# ========================
# Cursor IDE
# ========================
.cursor/

# ========================
# 依赖文件（消歧义）
# ========================
# requirements.txt 是正式依赖文件，保留追踪
# requirement.txt 是多余的别名文件（内容仅 -r requirements.txt），忽略
/requirement.txt

# ========================
# 自动生成文档
# ========================
/PROJECT_STRUCTURE.md

# ========================
# Windows 系统文件
# ========================
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ========================
# 常见 IDE / 编辑器
# ========================
.idea/
.vscode/
*.suo
*.user
*.userosscache
*.sln.docstates
