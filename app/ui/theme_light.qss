/* ===== Light Theme — llamacpp launcher ===== */

QMainWindow {
    background: #f8fafc;
}

QWidget {
    color: #1e293b;
    font-family: "Segoe UI", "Microsoft YaHei UI", sans-serif;
}

/* ---------- Toolbar ---------- */
QToolBar {
    background: #ffffff;
    border-bottom: 1px solid #e2e8f0;
    spacing: 6px;
    padding: 6px 10px;
}

/* ---------- GroupBox ---------- */
QGroupBox {
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    margin-top: 14px;
    padding: 14px 10px 10px 10px;
    background: #ffffff;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 12px;
    padding: 0 6px;
    color: #4f46e5;
    font-weight: bold;
    font-size: 13px;
}

QGroupBox QLabel {
    color: #64748b;
}

QGroupBox QCheckBox {
    color: #64748b;
}

/* ---------- Input Widgets ---------- */
QLineEdit, QComboBox, QSpinBox, QDoubleSpinBox {
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    padding: 5px 8px;
    background: #f1f5f9;
    color: #1e293b;
    selection-background-color: #6366f1;
    selection-color: #ffffff;
    min-height: 18px;
}

QLineEdit:focus, QComboBox:focus, QSpinBox:focus, QDoubleSpinBox:focus {
    border-color: #6366f1;
    background: #ffffff;
}

QLineEdit:disabled, QComboBox:disabled, QSpinBox:disabled, QDoubleSpinBox:disabled {
    background: #f1f5f9;
    color: #94a3b8;
    border-color: #e2e8f0;
}

QLabel:disabled {
    color: #c0c9d6;
}

QPlainTextEdit, QTextEdit {
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    padding: 6px 8px;
    background: #ffffff;
    color: #1e293b;
    selection-background-color: #6366f1;
    selection-color: #ffffff;
}

QPlainTextEdit:focus, QTextEdit:focus {
    border-color: #6366f1;
}

/* ---------- ComboBox dropdown ---------- */
QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: center right;
    width: 24px;
    border: none;
    background: transparent;
}

QComboBox::down-arrow {
    image: url({{ICONS}}/arrow-down-light.svg);
    width: 10px;
    height: 10px;
}

QComboBox QAbstractItemView {
    background: #ffffff;
    border: 1px solid #cbd5e1;
    selection-background-color: #ede9fe;
    selection-color: #4f46e5;
    color: #1e293b;
    padding: 4px;
    outline: none;
}

/* ---------- SpinBox arrows ---------- */
QSpinBox::up-button, QDoubleSpinBox::up-button {
    subcontrol-origin: border;
    subcontrol-position: top right;
    width: 20px;
    border: none;
    background: transparent;
}

QSpinBox::down-button, QDoubleSpinBox::down-button {
    subcontrol-origin: border;
    subcontrol-position: bottom right;
    width: 20px;
    border: none;
    background: transparent;
}

QSpinBox::up-button:hover, QDoubleSpinBox::up-button:hover,
QSpinBox::down-button:hover, QDoubleSpinBox::down-button:hover {
    background: #e2e8f0;
}

QSpinBox::up-arrow, QDoubleSpinBox::up-arrow {
    image: url({{ICONS}}/arrow-up-light.svg);
    width: 8px;
    height: 8px;
}

QSpinBox::down-arrow, QDoubleSpinBox::down-arrow {
    image: url({{ICONS}}/arrow-down-light.svg);
    width: 8px;
    height: 8px;
}

/* ---------- Buttons ---------- */
QPushButton {
    border: 1px solid #6366f1;
    border-radius: 6px;
    padding: 5px 14px;
    background: #4f46e5;
    color: #ffffff;
    font-weight: 500;
    min-height: 18px;
}

QPushButton:hover {
    background: #6366f1;
    border-color: #6366f1;
}

QPushButton:pressed {
    background: #4338ca;
    border-color: #4338ca;
}

QPushButton:disabled {
    border-color: #e2e8f0;
    background: #e2e8f0;
    color: #94a3b8;
}

QPushButton[flat="true"], QPushButton#themeToggleBtn {
    background: transparent;
    border: 1px solid #cbd5e1;
    color: #64748b;
    padding: 2px;
}

QPushButton[flat="true"]:hover, QPushButton#themeToggleBtn:hover {
    background: #f1f5f9;
    color: #1e293b;
    padding: 2px;
}

/* ---------- Start/Stop Toggle Button ---------- */
QPushButton#startStopBtn {
    background: #16a34a;
    border-color: #16a34a;
    min-width: 120px;
    font-weight: 600;
    color: #ffffff;
}

QPushButton#startStopBtn:hover {
    background: #22c55e;
    border-color: #22c55e;
}

QPushButton#startStopBtn:pressed {
    background: #15803d;
    border-color: #15803d;
}

QPushButton#startStopBtn[running="true"] {
    background: #dc2626;
    border-color: #dc2626;
    color: #ffffff;
}

QPushButton#startStopBtn[running="true"]:hover {
    background: #ef4444;
    border-color: #ef4444;
}

QPushButton#startStopBtn[running="true"]:pressed {
    background: #b91c1c;
    border-color: #b91c1c;
}

/* SSH mode: bright blue start, orange stop */
QPushButton#startStopBtn[ssh_mode="true"] {
    background: #3b82f6;
    border-color: #3b82f6;
    color: #ffffff;
}

QPushButton#startStopBtn[ssh_mode="true"]:hover {
    background: #60a5fa;
    border-color: #60a5fa;
}

QPushButton#startStopBtn[ssh_mode="true"]:pressed {
    background: #2563eb;
    border-color: #2563eb;
}

QPushButton#startStopBtn[ssh_mode="true"]:disabled {
    background: #cbd5e1;
    border-color: #cbd5e1;
    color: #94a3b8;
}

QPushButton#startStopBtn[ssh_mode="true"][running="true"] {
    background: #ea580c;
    border-color: #ea580c;
    color: #ffffff;
}

QPushButton#startStopBtn[ssh_mode="true"][running="true"]:hover {
    background: #f97316;
    border-color: #f97316;
}

QPushButton#startStopBtn[ssh_mode="true"][running="true"]:pressed {
    background: #c2410c;
    border-color: #c2410c;
}

/* ---------- CheckBox ---------- */
QCheckBox {
    spacing: 6px;
    color: #1e293b;
}

QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border: 1px solid #cbd5e1;
    border-radius: 4px;
    background: #ffffff;
}

QCheckBox::indicator:hover {
    border-color: #6366f1;
}

QCheckBox::indicator:checked {
    background: #4f46e5;
    border-color: #4f46e5;
    image: url({{ICONS}}/check-light.svg);
}

QCheckBox::indicator:checked:hover {
    background: #6366f1;
    border-color: #6366f1;
    image: url({{ICONS}}/check-light.svg);
}

/* ---------- ScrollBar ---------- */
QScrollBar:vertical {
    background: transparent;
    width: 8px;
    margin: 0;
    border: none;
}

QScrollBar::handle:vertical {
    background: #cbd5e1;
    min-height: 30px;
    border-radius: 4px;
}

QScrollBar::handle:vertical:hover {
    background: #94a3b8;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
    background: none;
    border: none;
}

QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}

QScrollBar:horizontal {
    background: transparent;
    height: 8px;
    margin: 0;
    border: none;
}

QScrollBar::handle:horizontal {
    background: #cbd5e1;
    min-width: 30px;
    border-radius: 4px;
}

QScrollBar::handle:horizontal:hover {
    background: #94a3b8;
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0;
    background: none;
    border: none;
}

QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal {
    background: none;
}

/* ---------- ScrollArea ---------- */
QScrollArea {
    border: none;
}

/* ---------- Splitter ---------- */
QSplitter::handle {
    background: #e2e8f0;
}

QSplitter::handle:horizontal {
    width: 2px;
}

QSplitter::handle:hover {
    background: #6366f1;
}

/* ---------- StatusBar ---------- */
QStatusBar {
    background: #ffffff;
    border-top: 1px solid #e2e8f0;
    padding: 2px 8px;
    font-size: 12px;
    color: #64748b;
}

QLabel#modeHintLabel {
    color: #000000;
    font-weight: 500;
}

QLabel#resourceLabel {
    color: #475569;
    font-size: 12px;
    font-family: "Consolas", "Cascadia Mono", monospace;
}

QLabel#installLink {
    font-size: 12px;
}

/* ---------- ProgressBar ---------- */
QProgressBar {
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    background: #f1f5f9;
    text-align: center;
    color: #1e293b;
    min-height: 18px;
    font-size: 11px;
}

QProgressBar::chunk {
    background: #4f46e5;
    border-radius: 5px;
}

/* ---------- Dialog ---------- */
QDialog {
    background: #f8fafc;
}

/* ---------- Label ---------- */
QLabel {
    color: #1e293b;
}

/* ---------- ToolTip ---------- */
QToolTip {
    background: #ffffff;
    color: #1e293b;
    border: 1px solid #cbd5e1;
    border-radius: 4px;
    padding: 4px 8px;
}

/* ---------- Slider ---------- */
QSlider::groove:horizontal {
    height: 4px;
    background: #e2e8f0;
    border-radius: 2px;
}

QSlider::sub-page:horizontal {
    background: #4f46e5;
    border-radius: 2px;
}

QSlider::add-page:horizontal {
    background: #e2e8f0;
    border-radius: 2px;
}

QSlider::handle:horizontal {
    background: #4f46e5;
    border: 2px solid #4f46e5;
    width: 14px;
    height: 14px;
    border-radius: 7px;
    margin: -5px 0;
}

QSlider::handle:horizontal:hover {
    background: #6366f1;
    border-color: #6366f1;
}

QSlider::handle:horizontal:pressed {
    background: #4338ca;
    border-color: #4338ca;
}

QSlider::handle:horizontal:disabled {
    background: #cbd5e1;
    border-color: #cbd5e1;
}

QSlider::sub-page:horizontal:disabled {
    background: #e2e8f0;
}

/* ---------- Menu ---------- */
QMenu {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    padding: 4px;
}

QMenu::item {
    padding: 6px 24px;
    border-radius: 4px;
}

QMenu::item:selected {
    background: #f1f5f9;
}

/* ---------- RPC Node Chip ---------- */
QWidget#RpcNodeChip {
    background: #ede9fe;
    border: 1px solid #c4b5fd;
    border-radius: 6px;
}

QWidget#RpcNodeChip QLabel {
    color: #4f46e5;
    font-size: 12px;
    background: transparent;
    border: none;
}

QPushButton#RpcChipDeleteBtn {
    background: transparent;
    border: none;
    color: #a78bfa;
    padding: 0px;
    font-size: 15px;
    font-weight: bold;
    min-height: 0px;
}

QPushButton#RpcChipDeleteBtn:hover {
    color: #7c3aed;
    background: transparent;
    border: none;
    padding: 0px;
}

QPushButton#rpcClearBtn {
    background: #cbd5e1;
    border-color: #94a3b8;
    color: #475569;
}

QPushButton#rpcClearBtn:hover {
    background: #94a3b8;
    border-color: #64748b;
    color: #1e293b;
}

QPushButton#rpcClearBtn:pressed {
    background: #64748b;
    border-color: #475569;
    color: #f8fafc;
}
